local Junkie = loadstring(game:HttpGet("https://jnkie.com/sdk/library.lua"))()

-- Configure your Junkie Project details
Junkie.service = "PXG4E"
Junkie.identifier = "1089317"
Junkie.provider = "PXG HUB KICK A LUCKY BLOCK"

-- This function runs ONLY after the key is verified
local function Success(key)
    getgenv().SCRIPT_KEY = key -- Store key for the main script if needed
    
    -- This is your "Extract Script" (The actual game hack)
    loadstring(game:HttpGet("https://raw.githubusercontent.com/ToraIsMe/ToraIsMe/main/0LuckyBlock"))()
end

-- Check if a key is already saved on the computer
if isfile and isfile("junkie_auth.txt") then
    local savedKey = readfile("junkie_auth.txt")
    local result = Junkie.check_key(savedKey)
    if result and result.valid then
        Success(savedKey)
        return -- Stop here, script loaded successfully
    end
end

-- If no valid saved key, show the Junkie UI
Junkie.setup_ui(function(key)
    local result = Junkie.check_key(key)
    if result and result.valid then
        -- Save the key so they don't have to re-enter it next time
        if writefile then
            writefile("junkie_auth.txt", key)
        end
        
        Success(key)
        return true -- Closes the Junkie UI
    else
        return false -- Keeps UI open (Invalid Key)
    end
end)
